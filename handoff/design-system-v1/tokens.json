{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "Moxa PoC Operational Design System v1.0",
  "version": "1.0.0",
  "source": {
    "gitCommit": "8cf7de1",
    "primaryCss": "assets/css/moxa-ds.css",
    "supplementalCss": "assets/css/microsite-remote-io.css"
  },
  "collections": {
    "Moxa / Primitives": {
      "modes": ["Value"],
      "tokens": {
        "color/teal/500": {"type": "COLOR", "value": "#008787", "scope": [], "css": "var(--moxa-teal)"},
        "color/teal/700": {"type": "COLOR", "value": "#006B6B", "scope": [], "css": "var(--moxa-teal-700)"},
        "color/teal/100": {"type": "COLOR", "value": "#E7F5F4", "scope": [], "css": "var(--moxa-teal-100)"},
        "color/navy/800": {"type": "COLOR", "value": "#082F49", "scope": [], "css": "var(--moxa-navy)"},
        "color/cyan/400": {"type": "COLOR", "value": "#40CBD0", "scope": [], "css": "var(--moxa-cyan)"},
        "color/orange/400": {"type": "COLOR", "value": "#F39A61", "scope": [], "css": "var(--moxa-orange)"},
        "color/ink/900": {"type": "COLOR", "value": "#162F3A", "scope": [], "css": "var(--moxa-ink)"},
        "color/muted/600": {"type": "COLOR", "value": "#637781", "scope": [], "css": "var(--moxa-muted)"},
        "color/line/200": {"type": "COLOR", "value": "#D7E3E4", "scope": [], "css": "var(--moxa-line)"},
        "color/surface/050": {"type": "COLOR", "value": "#F4F8F8", "scope": [], "css": "var(--moxa-surface)"},
        "color/white": {"type": "COLOR", "value": "#FFFFFF", "scope": [], "css": "var(--moxa-white)"},
        "color/deep/800": {"type": "COLOR", "value": "#073F47", "scope": [], "css": "var(--rio-deep)"},
        "color/rio-ink/900": {"type": "COLOR", "value": "#102F3F", "scope": [], "css": "var(--rio-ink)"},
        "color/rio-text/600": {"type": "COLOR", "value": "#536B72", "scope": [], "css": "var(--rio-text)"},
        "color/rio-line/200": {"type": "COLOR", "value": "#D5E3E4", "scope": [], "css": "var(--rio-line)"},
        "color/rio-soft/050": {"type": "COLOR", "value": "#F2F7F7", "scope": [], "css": "var(--rio-soft)"}
      }
    },
    "Moxa / Semantic Color": {
      "modes": ["Light", "Dark Campaign", "Inverse"],
      "tokens": {
        "color/bg/page": {"type": "COLOR", "scope": ["FRAME_FILL", "SHAPE_FILL"], "css": "var(--moxa-white)", "values": {"Light": "{color/white}", "Dark Campaign": "{color/deep/800}", "Inverse": "{color/navy/800}"}},
        "color/bg/surface": {"type": "COLOR", "scope": ["FRAME_FILL", "SHAPE_FILL"], "css": "var(--moxa-surface)", "values": {"Light": "{color/surface/050}", "Dark Campaign": "{color/navy/800}", "Inverse": "{color/deep/800}"}},
        "color/bg/brand": {"type": "COLOR", "scope": ["FRAME_FILL", "SHAPE_FILL"], "css": "var(--moxa-teal)", "values": {"Light": "{color/teal/500}", "Dark Campaign": "{color/teal/500}", "Inverse": "{color/teal/500}"}},
        "color/bg/brand-hover": {"type": "COLOR", "scope": ["FRAME_FILL", "SHAPE_FILL"], "css": "var(--moxa-teal-700)", "values": {"Light": "{color/teal/700}", "Dark Campaign": "{color/cyan/400}", "Inverse": "{color/cyan/400}"}},
        "color/bg/subtle-brand": {"type": "COLOR", "scope": ["FRAME_FILL", "SHAPE_FILL"], "css": "var(--moxa-teal-100)", "values": {"Light": "{color/teal/100}", "Dark Campaign": "{color/deep/800}", "Inverse": "{color/deep/800}"}},
        "color/text/primary": {"type": "COLOR", "scope": ["TEXT_FILL"], "css": "var(--moxa-ink)", "values": {"Light": "{color/ink/900}", "Dark Campaign": "{color/white}", "Inverse": "{color/white}"}},
        "color/text/secondary": {"type": "COLOR", "scope": ["TEXT_FILL"], "css": "var(--moxa-muted)", "values": {"Light": "{color/muted/600}", "Dark Campaign": "{color/teal/100}", "Inverse": "{color/teal/100}"}},
        "color/text/brand": {"type": "COLOR", "scope": ["TEXT_FILL"], "css": "var(--moxa-teal)", "values": {"Light": "{color/teal/500}", "Dark Campaign": "{color/cyan/400}", "Inverse": "{color/cyan/400}"}},
        "color/text/on-brand": {"type": "COLOR", "scope": ["TEXT_FILL"], "css": "var(--moxa-white)", "values": {"Light": "{color/white}", "Dark Campaign": "{color/white}", "Inverse": "{color/white}"}},
        "color/border/default": {"type": "COLOR", "scope": ["STROKE_COLOR"], "css": "var(--moxa-line)", "values": {"Light": "{color/line/200}", "Dark Campaign": "{color/muted/600}", "Inverse": "{color/muted/600}"}},
        "color/border/brand": {"type": "COLOR", "scope": ["STROKE_COLOR"], "css": "var(--moxa-teal)", "values": {"Light": "{color/teal/500}", "Dark Campaign": "{color/cyan/400}", "Inverse": "{color/cyan/400}"}},
        "color/focus/ring": {"type": "COLOR", "scope": ["STROKE_COLOR"], "css": "var(--moxa-cyan)", "values": {"Light": "{color/cyan/400}", "Dark Campaign": "{color/cyan/400}", "Inverse": "{color/cyan/400}"}},
        "color/action/primary": {"type": "COLOR", "scope": ["FRAME_FILL", "SHAPE_FILL"], "css": "var(--moxa-teal)", "values": {"Light": "{color/teal/500}", "Dark Campaign": "{color/teal/500}", "Inverse": "{color/teal/500}"}},
        "color/action/primary-hover": {"type": "COLOR", "scope": ["FRAME_FILL", "SHAPE_FILL"], "css": "var(--moxa-teal-700)", "values": {"Light": "{color/teal/700}", "Dark Campaign": "{color/cyan/400}", "Inverse": "{color/cyan/400}"}},
        "color/action/hero": {"type": "COLOR", "scope": ["FRAME_FILL", "SHAPE_FILL"], "css": "var(--moxa-orange)", "values": {"Light": "{color/orange/400}", "Dark Campaign": "{color/orange/400}", "Inverse": "{color/orange/400}"}}
      }
    },
    "Moxa / Spacing": {
      "modes": ["Value"],
      "tokens": {
        "spacing/1": {"type": "FLOAT", "value": 4, "scope": ["GAP"], "css": "var(--moxa-space-1)"},
        "spacing/2": {"type": "FLOAT", "value": 8, "scope": ["GAP"], "css": "var(--moxa-space-2)"},
        "spacing/3": {"type": "FLOAT", "value": 12, "scope": ["GAP"], "css": "var(--moxa-space-3)"},
        "spacing/4": {"type": "FLOAT", "value": 16, "scope": ["GAP"], "css": "var(--moxa-space-4)"},
        "spacing/5": {"type": "FLOAT", "value": 24, "scope": ["GAP"], "css": "var(--moxa-space-5)"},
        "spacing/6": {"type": "FLOAT", "value": 32, "scope": ["GAP"], "css": "var(--moxa-space-6)"},
        "spacing/7": {"type": "FLOAT", "value": 48, "scope": ["GAP"], "css": "var(--moxa-space-7)"},
        "spacing/8": {"type": "FLOAT", "value": 64, "scope": ["GAP"], "css": "var(--moxa-space-8)"}
      }
    },
    "Moxa / Radius": {
      "modes": ["Value"],
      "tokens": {
        "radius/sm": {"type": "FLOAT", "value": 4, "scope": ["CORNER_RADIUS"], "css": "var(--moxa-radius-1)"},
        "radius/md": {"type": "FLOAT", "value": 8, "scope": ["CORNER_RADIUS"], "css": "var(--moxa-radius-2)"},
        "radius/lg": {"type": "FLOAT", "value": 12, "scope": ["CORNER_RADIUS"], "css": "var(--moxa-radius-3)"},
        "radius/pill": {"type": "FLOAT", "value": 999, "scope": ["CORNER_RADIUS"], "css": "var(--moxa-radius-pill)"}
      }
    },
    "Moxa / Sizing": {
      "modes": ["Value"],
      "tokens": {
        "size/content/max": {"type": "FLOAT", "value": 1240, "scope": ["WIDTH_HEIGHT"], "css": "var(--moxa-content)"},
        "size/control/sm": {"type": "FLOAT", "value": 34, "scope": ["WIDTH_HEIGHT"], "css": "34px"},
        "size/control/md": {"type": "FLOAT", "value": 44, "scope": ["WIDTH_HEIGHT"], "css": "44px"},
        "size/control/lg": {"type": "FLOAT", "value": 48, "scope": ["WIDTH_HEIGHT"], "css": "48px"},
        "size/icon/md": {"type": "FLOAT", "value": 20, "scope": ["WIDTH_HEIGHT"], "css": "20px"},
        "size/touch/min": {"type": "FLOAT", "value": 44, "scope": ["WIDTH_HEIGHT"], "css": "44px"}
      }
    },
    "Moxa / Typography": {
      "modes": ["Desktop", "Compact"],
      "tokens": {
        "type/display/size": {"type": "FLOAT", "scope": ["FONT_SIZE"], "css": "clamp(2.5rem, 5vw, 4.75rem)", "values": {"Desktop": 64, "Compact": 44}},
        "type/h1/size": {"type": "FLOAT", "scope": ["FONT_SIZE"], "css": "clamp(2.25rem, 4vw, 4rem)", "values": {"Desktop": 56, "Compact": 40}},
        "type/h2/size": {"type": "FLOAT", "scope": ["FONT_SIZE"], "css": "clamp(2rem, 3vw, 3.25rem)", "values": {"Desktop": 44, "Compact": 32}},
        "type/h3/size": {"type": "FLOAT", "scope": ["FONT_SIZE"], "css": "1.25rem", "values": {"Desktop": 20, "Compact": 20}},
        "type/body-lg/size": {"type": "FLOAT", "scope": ["FONT_SIZE"], "css": "1.125rem", "values": {"Desktop": 18, "Compact": 18}},
        "type/body/size": {"type": "FLOAT", "scope": ["FONT_SIZE"], "css": "1rem", "values": {"Desktop": 16, "Compact": 16}},
        "type/body-sm/size": {"type": "FLOAT", "scope": ["FONT_SIZE"], "css": "0.875rem", "values": {"Desktop": 14, "Compact": 14}},
        "type/label/size": {"type": "FLOAT", "scope": ["FONT_SIZE"], "css": "0.75rem", "values": {"Desktop": 12, "Compact": 12}},
        "type/display/line": {"type": "FLOAT", "scope": ["LINE_HEIGHT"], "css": "1.02", "values": {"Desktop": 65, "Compact": 47}},
        "type/heading/line": {"type": "FLOAT", "scope": ["LINE_HEIGHT"], "css": "1.08", "values": {"Desktop": 60, "Compact": 43}},
        "type/body/line": {"type": "FLOAT", "scope": ["LINE_HEIGHT"], "css": "1.55", "values": {"Desktop": 25, "Compact": 25}}
      }
    },
    "Moxa / Motion": {
      "modes": ["Value"],
      "tokens": {
        "motion/duration/fast": {"type": "FLOAT", "value": 150, "scope": [], "css": "150ms"},
        "motion/duration/default": {"type": "FLOAT", "value": 180, "scope": [], "css": "180ms"},
        "motion/duration/disclosure": {"type": "FLOAT", "value": 300, "scope": [], "css": "300ms"},
        "motion/easing/standard": {"type": "STRING", "value": "cubic-bezier(.22,.61,.36,1)", "scope": [], "css": "var(--rio-ease)"}
      }
    }
  }
}
